#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_buffer_reference : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 64) out;

struct GpuMeshletDrawDescriptor {
    uint meshletOffset;
    uint meshletCount;
    uint materialIndex;
    uint padding; 
};

struct GpuMeshletDescriptor {
    uint vertexIndicesOffset;
    uint vertexCount;
    uint triangleIndicesOffset;
    uint triangleCount;
};

struct GpuVertexPosition {
    vec3 position;
    uint packedIndex;
};

layout(buffer_reference, std430) readonly buffer DrawDescBuffer { GpuMeshletDrawDescriptor data[]; };
layout(buffer_reference, std430) readonly buffer MeshletDescBuffer { GpuMeshletDescriptor data[]; };
layout(buffer_reference, std430) readonly buffer VertexIndicesBuffer { uint data[]; };
layout(buffer_reference, std430) readonly buffer TriangleIndicesBuffer { uint data[]; };
layout(buffer_reference, std430) readonly buffer PositionBuffer { GpuVertexPosition data[]; };

layout(push_constant) uniform PushConstants {
    uint64_t positionsAddr;
    uint64_t attributesAddr;
    uint64_t indicesAddr;
    uint64_t nodesAddr;
    mat4 viewProj;
    uint64_t meshletDescAddr;
    uint64_t meshletVertexIndicesAddr;
    uint64_t meshletTriangleIndicesAddr;
    uint64_t drawDescAddr; 
} pc;

layout(location = 0) out vec3 outColor[];

vec3 hash3(uint n) {
    n = (n << 13U) ^ n;
    n = n * (n * n * 15731U + 789221U) + 1376312589U;
    uvec3 u = uvec3(n, n * 16807U, n * 48271U);
    return vec3(u & uvec3(0x7fffffffU)) / float(0x7fffffff);
}

void main() {
    uint threadIdx = gl_LocalInvocationID.x;

    DrawDescBuffer drawBuf = DrawDescBuffer(pc.drawDescAddr);
    GpuMeshletDrawDescriptor drawDesc = drawBuf.data[gl_DrawID];
    
    uint globalMeshletIdx = drawDesc.meshletOffset + gl_WorkGroupID.x;

    MeshletDescBuffer descBuf = MeshletDescBuffer(pc.meshletDescAddr);
    GpuMeshletDescriptor meshlet = descBuf.data[globalMeshletIdx];

    if (threadIdx == 0) {
        SetMeshOutputsEXT(uint(meshlet.vertexCount), uint(meshlet.triangleCount));
    }

    vec3 meshletColor = hash3(globalMeshletIdx);

    VertexIndicesBuffer vtxIdxBuf = VertexIndicesBuffer(pc.meshletVertexIndicesAddr);
    PositionBuffer posBuf = PositionBuffer(pc.positionsAddr);

    for (uint i = threadIdx; i < uint(meshlet.vertexCount); i += 32) {
        uint globalVtxIdx = vtxIdxBuf.data[meshlet.vertexIndicesOffset + i];
        GpuVertexPosition v = posBuf.data[globalVtxIdx];
        
        gl_MeshVerticesEXT[i].gl_Position = pc.viewProj * vec4(v.position, 1.0);
        outColor[i] = meshletColor;
    }

    TriangleIndicesBuffer triIdxBuf = TriangleIndicesBuffer(pc.meshletTriangleIndicesAddr);

    for (uint i = threadIdx; i < uint(meshlet.triangleCount); i += 32) {
        uint baseOffset = meshlet.triangleIndicesOffset + (i * 3);
        
        uint i0 = uint(triIdxBuf.data[baseOffset + 0]);
        uint i1 = uint(triIdxBuf.data[baseOffset + 1]);
        uint i2 = uint(triIdxBuf.data[baseOffset + 2]);

        gl_PrimitiveTriangleIndicesEXT[i] = uvec3(i0, i1, i2);
    }
}